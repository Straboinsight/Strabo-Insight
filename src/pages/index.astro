<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Strabo Insight — Supply Chain Geopolitical Intelligence</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=Space+Mono&family=Nunito+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --navy:       #091E38;
  --navy-deep:  #060F1C;
  --navy-mid:   #0d3d6e;
  --gold:       #C49A4A;
  --gold-dim:   rgba(196,154,74,0.18);
  --gold-line:  rgba(196,154,74,0.3);
  --slate:      #7A8FA0;
  --slate-dim:  rgba(122,143,160,0.18);
  --paper:      #F7F4EE;
  --paper-warm: #EDE8DE;
  --bd:         rgba(122,143,160,0.14);
  --bdl:        rgba(9,30,56,0.11);
  --fh:         'EB Garamond', Georgia, serif;
  --fb:         'DM Sans', system-ui, sans-serif;
  --fm:         'Space Mono', monospace;
}

html { scroll-behavior: smooth; }
body { background: var(--navy); color: var(--paper); font-family: var(--fb); font-weight: 400; line-height: 1.75; overflow-x: hidden; font-size: 16px; }

/* ─── GRAIN OVERLAY ─── */
body::before {
  content: '';
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
  opacity: 0.022;
}

/* ─── NAV ─── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  display: flex; justify-content: space-between; align-items: center;
  padding: 1.1rem 3rem;
  border-bottom: 0.5px solid var(--bd);
  background: rgba(9,30,56,0.95);
  backdrop-filter: blur(16px) saturate(1.4);
  transition: padding 0.3s ease;
}
nav.scrolled { padding: 0.75rem 3rem; }
.nav-logo { display: flex; flex-direction: column; align-items: flex-start; text-decoration: none; gap: 2px; }
.nav-logo .lg-t { font-family: var(--fh); font-size: 1.45rem; font-weight: 500; letter-spacing: 0.12em; color: var(--paper); line-height: 1; }
.nav-logo .lg-b { font-family: var(--fb); font-size: 0.48rem; font-weight: 600; letter-spacing: 0.42em; color: var(--gold); text-transform: uppercase; line-height: 1; }
nav ul { display: flex; align-items: center; gap: 2.25rem; list-style: none; }
nav ul a { font-family: var(--fb); font-size: 0.7rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(247,244,238,0.5); text-decoration: none; transition: color 0.2s; }
nav ul a:hover { color: var(--paper); }
.nav-cta {
  background: transparent; color: var(--gold) !important;
  border: 0.5px solid var(--gold-line); padding: 0.5rem 1.2rem; border-radius: 1px;
  transition: all 0.2s !important;
}
.nav-cta:hover { background: var(--gold-dim) !important; color: var(--paper) !important; }

/* ─── BUTTONS ─── */
.btn-p {
  display: inline-block; font-family: var(--fb); font-size: 0.72rem; font-weight: 600;
  letter-spacing: 0.12em; text-transform: uppercase;
  background: var(--gold); color: var(--navy-deep);
  padding: 0.95rem 2.25rem; border-radius: 1px; text-decoration: none;
  transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  position: relative; overflow: hidden;
}
.btn-p::after { content: ''; position: absolute; inset: 0; background: rgba(255,255,255,0); transition: background 0.2s; }
.btn-p:hover { background: #d4aa5a; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(196,154,74,0.22); }
.btn-s {
  display: inline-block; font-family: var(--fb); font-size: 0.72rem; font-weight: 600;
  letter-spacing: 0.12em; text-transform: uppercase;
  border: 0.5px solid rgba(122,143,160,0.35); color: rgba(247,244,238,0.65);
  padding: 0.95rem 2.25rem; border-radius: 1px; text-decoration: none;
  transition: all 0.2s;
}
.btn-s:hover { border-color: var(--slate); color: var(--paper); background: var(--slate-dim); }

/* ─── LABEL ─── */
.lbl {
  font-family: var(--fm); font-size: 0.6rem; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--gold); opacity: 0.7;
  display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2rem;
}
.lbl::before { content: ''; display: block; width: 24px; height: 0.5px; background: var(--gold); opacity: 0.4; }
.lbl-dark { color: rgba(9,30,56,0.4); }
.lbl-dark::before { background: rgba(9,30,56,0.2); }

/* ─── HERO ─── */
.hero {
  min-height: 100dvh; display: flex; flex-direction: column; justify-content: center;
  padding: 0 3rem; position: relative; overflow: hidden;
  border-bottom: 0.5px solid var(--bd);
}
.hero-content {
  display: flex; flex-direction: column; justify-content: center;
  padding: 8rem 0 6rem; max-width: 680px;
  position: relative; z-index: 1;
}
.hero-lbl { font-family: var(--fm); font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); opacity: 0; animation: fadeUp 0.6s ease forwards 0.1s; margin-bottom: 2rem; }
.hero h1 { font-family: var(--fh); font-size: clamp(3rem, 5.5vw, 6.5rem); font-weight: 500; line-height: 1.02; margin-bottom: 2rem; opacity: 0; animation: fadeUp 0.7s ease forwards 0.25s; }
.hero h1 em { font-style: normal; color: var(--gold); }
.hero-sub { font-size: 1rem; color: rgba(247,244,238,0.62); max-width: 460px; line-height: 1.8; margin-bottom: 2.75rem; opacity: 0; animation: fadeUp 0.7s ease forwards 0.4s; }
.hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; opacity: 0; animation: fadeUp 0.7s ease forwards 0.55s; }


.globe-svg { display: none; }

/* ─── TICKER ─── */
.ticker {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 150;
  font-family: var(--fm); font-size: 0.55rem; letter-spacing: 0.14em;
  text-transform: uppercase; color: rgba(122,143,160,0.3);
  white-space: nowrap; overflow: hidden;
  border-top: 0.5px solid var(--bd); padding: 0.6rem 0;
  background: rgba(9,30,56,0.9); backdrop-filter: blur(8px);
}
.ticker span { display: inline-block; animation: tick 45s linear infinite; }
@keyframes tick { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

/* ─── SECTIONS ─── */
.sec   { padding: 8rem 3rem; border-bottom: 0.5px solid var(--bd); position: relative; }
.sec-l { padding: 8rem 3rem; border-bottom: 0.5px solid var(--bdl); background: var(--paper); color: var(--navy); position: relative; }

/* ─── PROBLEM ─── */
.prob-header { display: grid; grid-template-columns: 1.2fr 1fr; gap: 6rem; align-items: end; margin-bottom: 6rem; }
.prob-header h2 { font-family: var(--fh); font-size: clamp(2.5rem,4vw,4.75rem); font-weight: 500; line-height: 1.05; }
.prob-header h2 em { font-style: normal; color: var(--gold); }
.prob-body p { font-size: 0.97rem; color: rgba(247,244,238,0.62); margin-bottom: 1.25rem; line-height: 1.85; }
.prob-body p:last-child { margin: 0; }
.prob-body strong { color: var(--paper); font-weight: 500; }
.bento { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; border: 0.5px solid var(--bd); border-radius: 2px; overflow: hidden; }
.bento-item { padding: 3rem 2.5rem; border-right: 0.5px solid var(--bd); position: relative; overflow: hidden; transition: background 0.3s; }
.bento-item:last-child { border-right: none; }
.bento-item::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px; background: linear-gradient(to right, var(--gold), transparent); transform: scaleX(0); transform-origin: left; transition: transform 0.4s ease; }
.bento-item:hover::after { transform: scaleX(1); }
.bento-item:hover { background: rgba(196,154,74,0.03); }
.bento-n { font-family: var(--fh); font-size: 4.5rem; font-weight: 500; color: var(--gold); line-height: 1; margin-bottom: 0.75rem; }
.bento-l { font-size: 0.82rem; color: rgba(247,244,238,0.5); line-height: 1.65; margin-bottom: 0.6rem; }
.bento-src { font-family: var(--fm); font-size: 0.55rem; color: rgba(122,143,160,0.3); letter-spacing: 0.08em; }

/* ─── OFFERS ─── */
.offer-head { max-width: 640px; margin-bottom: 4.5rem; }
.offer-head h2 { font-family: var(--fh); font-size: clamp(2.25rem,3.5vw,3.75rem); font-weight: 500; line-height: 1.08; color: var(--navy); margin-bottom: 1rem; }
.offer-head p { font-size: 0.97rem; color: rgba(9,30,56,0.6); line-height: 1.75; }
.offers { display: grid; grid-template-columns: 1.1fr 1fr; gap: 1.25rem; }
.card { border: 0.5px solid var(--bdl); border-radius: 2px; padding: 3rem; background: var(--paper-warm); transition: box-shadow 0.3s; }
.card:hover { box-shadow: 0 12px 40px rgba(9,30,56,0.08); }
.card.feat { background: var(--navy); border-color: var(--gold-line); color: var(--paper); position: relative; overflow: hidden; }
.card.feat::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(to right, var(--gold), rgba(196,154,74,0.2)); }
.card-tag { font-family: var(--fm); font-size: 0.55rem; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(9,30,56,0.4); display: block; margin-bottom: 1.75rem; }
.card.feat .card-tag { color: var(--gold); opacity: 0.8; }
.card h3 { font-family: var(--fh); font-size: 2rem; font-weight: 500; margin-bottom: 0.5rem; }
.card-price { font-family: var(--fh); font-size: 3rem; font-weight: 500; color: var(--navy); margin-bottom: 0.25rem; line-height: 1; }
.card-price span { font-family: var(--fb); font-size: 0.78rem; font-weight: 400; color: rgba(9,30,56,0.4); }
.card.feat .card-price { color: var(--gold); }
.card.feat .card-price span { color: rgba(196,154,74,0.5); }
.card-delivery { font-family: var(--fm); font-size: 0.6rem; color: rgba(9,30,56,0.4); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1.5rem; }
.card.feat .card-delivery { color: rgba(196,154,74,0.5); }
.card-desc { font-size: 0.92rem; line-height: 1.75; margin-bottom: 2rem; color: rgba(9,30,56,0.62); }
.card.feat .card-desc { color: rgba(247,244,238,0.62); }
.card ul { list-style: none; margin-bottom: 2rem; border-top: 0.5px solid var(--bdl); padding-top: 1.5rem; }
.card.feat ul { border-top-color: var(--bd); }
.card ul li { font-size: 0.875rem; color: rgba(9,30,56,0.68); padding: 0.55rem 0; border-bottom: 0.5px solid rgba(9,30,56,0.06); display: flex; gap: 0.875rem; align-items: flex-start; line-height: 1.55; }
.card.feat ul li { color: rgba(247,244,238,0.62); border-bottom-color: rgba(122,143,160,0.08); }
.card ul li::before { content: '—'; color: var(--gold); opacity: 0.6; flex-shrink: 0; margin-top: 1px; font-size: 0.8rem; }
.card.feat ul li::before { opacity: 1; }
.founding { margin-bottom: 2rem; padding: 1.25rem 1.5rem; border: 0.5px solid var(--gold-line); border-radius: 1px; background: var(--gold-dim); }
.founding-tag { font-family: var(--fm); font-size: 0.55rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.5rem; display: block; }
.founding p { font-size: 0.82rem; color: rgba(247,244,238,0.62); line-height: 1.65; }
.founding-light { border-color: rgba(9,30,56,0.12); background: rgba(9,30,56,0.04); }
.founding-light .founding-tag { color: rgba(9,30,56,0.45); }
.founding-light p { color: rgba(9,30,56,0.62); }

/* ─── HOW IT WORKS ─── */
.how-head { max-width: 640px; margin-bottom: 4rem; }
.how-head h2 { font-family: var(--fh); font-size: clamp(2.25rem,3.5vw,3.75rem); font-weight: 500; line-height: 1.05; margin-bottom: 1rem; }
.how-head p { font-size: 0.95rem; color: rgba(247,244,238,0.5); line-height: 1.75; }
.how { display: grid; grid-template-columns: repeat(5,1fr); border: 0.5px solid var(--bd); border-radius: 2px; overflow: hidden; }
.step { padding: 3rem 2rem 2.5rem; border-right: 0.5px solid var(--bd); position: relative; transition: background 0.3s; }
.step:last-child { border-right: none; }
.step:hover { background: rgba(196,154,74,0.03); }
.step-n { font-family: var(--fh); font-size: 4rem; font-weight: 400; color: rgba(196,154,74,0.1); line-height: 1; margin-bottom: 1.25rem; }
.step-t { font-family: var(--fm); font-size: 0.6rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gold); opacity: 0.8; margin-bottom: 0.875rem; }
.step-b { font-size: 0.875rem; color: rgba(247,244,238,0.55); line-height: 1.7; }

/* ─── ABOUT ─── */
.about { display: grid; grid-template-columns: 280px 1fr; gap: 8rem; align-items: start; }
.about-l { position: sticky; top: 8rem; }
.about-l h2 { font-family: var(--fh); font-size: 3.25rem; font-weight: 500; line-height: 1; margin-bottom: 0.35rem; }
.about-l h2 em { font-style: normal; color: var(--gold); }
.about-t { font-family: var(--fm); font-size: 0.58rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); opacity: 0.7; margin-bottom: 2.25rem; }
.about-links { display: flex; flex-direction: column; gap: 0.7rem; }
.about-links a { font-family: var(--fb); font-size: 0.78rem; font-weight: 500; color: rgba(247,244,238,0.38); text-decoration: none; display: flex; align-items: center; gap: 0.6rem; transition: color 0.2s; letter-spacing: 0.02em; }
.about-links a:hover { color: var(--gold); }
.about-links a::before { content: '↗'; font-size: 0.72rem; opacity: 0.6; }
.about-r { border-left: 0.5px solid var(--bd); padding-left: 4rem; }
.about-r p { font-size: 1.02rem; color: rgba(247,244,238,0.65); margin-bottom: 1.75rem; line-height: 1.85; }
.about-r p strong { color: var(--paper); font-weight: 500; }
.about-r p:last-child { margin: 0; }
.about-r .pull { font-family: var(--fb); font-size: 1.02rem; font-style: normal; font-weight: 400; color: rgba(247,244,238,0.65); line-height: 1.85; margin-bottom: 1.75rem; }
.sig { font-family: var(--fm); font-size: 0.62rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gold) !important; opacity: 0.8; margin-top: 2rem !important; }

/* ─── NEWSLETTER ─── */
.nl { padding: 8rem 3rem; background: var(--navy-deep); border-bottom: 0.5px solid var(--bd); }
.nl-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
.nl-inner h2 { font-family: var(--fh); font-size: clamp(2rem,2.75vw,3rem); font-weight: 500; line-height: 1.1; margin-bottom: 1.25rem; }
.nl-inner h2 em { font-style: normal; color: var(--gold); }
.nl-inner p { font-size: 0.95rem; color: rgba(247,244,238,0.5); line-height: 1.8; }
.nl-form { margin-bottom: 1rem; }
.nl-form a { display: inline-block; background: var(--gold); color: var(--navy-deep); border: none; padding: 1rem 1.5rem; font-family: var(--fm); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer; white-space: nowrap; transition: background 0.2s; text-decoration: none; border-radius: 1px; }
.nl-form a:hover { background: #d4aa5a; }
.nl-fine { font-family: var(--fm); font-size: 0.55rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(122,143,160,0.25); }

/* ─── CONTACT ─── */
.contact-sec { padding: 8rem 3rem; border-bottom: 0.5px solid var(--bd); }
.contact { display: grid; grid-template-columns: 1fr 1fr; gap: 8rem; align-items: start; }
.contact h2 { font-family: var(--fh); font-size: clamp(2.5rem,3.75vw,4.25rem); font-weight: 500; line-height: 1.02; margin-bottom: 1.25rem; }
.contact > div > p { font-size: 0.95rem; color: rgba(247,244,238,0.55); line-height: 1.8; margin-bottom: 0.5rem; }
.c-email { margin-top: 1.75rem !important; font-family: var(--fm) !important; font-size: 0.68rem !important; color: var(--gold) !important; opacity: 0.65; letter-spacing: 0.1em; }
.c-form { display: flex; flex-direction: column; gap: 1.1rem; }
.f-field { display: flex; flex-direction: column; gap: 0.45rem; }
.f-field label { font-family: var(--fm); font-size: 0.58rem; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(122,143,160,0.5); }
.f-field input, .f-field textarea, .f-field select {
  background: rgba(122,143,160,0.05); border: 0.5px solid rgba(122,143,160,0.18);
  border-radius: 1px; padding: 0.9rem 1.1rem; color: var(--paper);
  font-family: var(--fb); font-size: 0.9rem; outline: none;
  transition: border-color 0.2s, background 0.2s; width: 100%;
}
.f-field select { appearance: none; cursor: pointer; }
.f-field select option { background: var(--navy); color: var(--paper); }
.f-field input:focus, .f-field textarea:focus, .f-field select:focus { border-color: var(--gold-line); background: rgba(196,154,74,0.03); }
.f-field input::placeholder, .f-field textarea::placeholder { color: rgba(122,143,160,0.28); }
.f-field textarea { resize: vertical; min-height: 130px; }
.f-fine { font-family: var(--fm); font-size: 0.58rem; letter-spacing: 0.1em; color: rgba(122,143,160,0.28); margin-top: 0.75rem; }

/* ─── CLOSING CTA ─── */
/* ─── CLOSING CTA ─── */
.closing { padding: 9rem 3rem 8rem; border-bottom: 0.5px solid var(--bd); background: var(--navy-deep); position: relative; overflow: hidden; }
.closing::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(196,154,74,0.04), transparent); pointer-events: none; }
.closing-inner { max-width: 720px; margin: 0 auto; text-align: center; }
.closing h2 { font-family: var(--fh); font-size: clamp(3rem,5vw,5.5rem); font-weight: 500; line-height: 1.02; margin-bottom: 1.25rem; }
.closing h2 em { font-style: normal; color: var(--gold); }
.closing p { font-size: 0.97rem; color: rgba(247,244,238,0.5); margin-bottom: 5rem; }
.closing-offers { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; text-align: left; }
.closing-card { border: 0.5px solid var(--bd); border-radius: 2px; padding: 2.75rem; transition: border-color 0.3s, background 0.3s; }
.closing-card:hover { border-color: var(--gold-line); background: rgba(196,154,74,0.025); }
.closing-card h3 { font-family: var(--fh); font-size: 1.65rem; font-weight: 500; margin-bottom: 0.5rem; }
.closing-card .price { font-family: var(--fh); font-size: 2.25rem; font-weight: 500; color: var(--gold); margin-bottom: 1.75rem; line-height: 1; }
.closing-card .price span { font-family: var(--fb); font-size: 0.75rem; color: rgba(196,154,74,0.4); }
.closing-card.feat { background: var(--paper-warm); border-color: var(--bdl); color: var(--navy); }
.closing-card.feat:hover { border-color: rgba(9,30,56,0.25); background: var(--paper); }
.closing-card.feat h3 { color: var(--navy); }
.closing-card.feat .price { color: var(--navy); }
.closing-card.feat .price span { color: rgba(9,30,56,0.4); }

/* ─── DIVIDER ─── */
.rule { font-family: var(--fm); font-size: 0.52rem; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(170,179,184,0.4); text-align: center; padding: 1.5rem; background: #0B315A; border-top: 0.5px solid rgba(170,179,184,0.14); border-bottom: 0.5px solid rgba(170,179,184,0.14); }

/* ─── FOOTER ─── */
footer {
  padding: 2.75rem 3rem; display: flex; justify-content: space-between;
  align-items: center; flex-wrap: wrap; gap: 1rem;
  background: var(--navy-deep); padding-bottom: 4rem;
}
.f-logo { display: flex; flex-direction: column; align-items: flex-start; text-decoration: none; gap: 3px; }
.f-logo .lg-t { font-family: var(--fh); font-size: 1.1rem; font-weight: 500; letter-spacing: 0.12em; color: var(--paper); line-height: 1; }
.f-logo .lg-b { font-family: var(--fb); font-size: 0.42rem; font-weight: 600; letter-spacing: 0.4em; color: var(--gold); text-transform: uppercase; line-height: 1; }
.f-links { display: flex; gap: 1.75rem; }
.f-links a { font-family: var(--fm); font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(122,143,160,0.35); text-decoration: none; transition: color 0.2s; }
.f-links a:hover { color: var(--gold); }
.f-copy { font-family: var(--fm); font-size: 0.55rem; color: rgba(122,143,160,0.2); letter-spacing: 0.08em; }

/* ─── ANIMATIONS ─── */
@keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
.reveal { opacity: 0; transform: translateY(22px); transition: opacity 0.7s ease, transform 0.7s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }
.reveal-delay-1 { transition-delay: 0.1s; }
.reveal-delay-2 { transition-delay: 0.2s; }
.reveal-delay-3 { transition-delay: 0.3s; }

/* Globe SVG animations */
